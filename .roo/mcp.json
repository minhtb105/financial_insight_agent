{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp"
            ],
            "env": {
                "DEFAULT_MINIMUM_TOKENS": ""
            }
        },
        "github": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITHUB_PERSONAL_ACCESS_TOKEN",
                "-e",
                "GITHUB_TOOLSETS",
                "-e",
                "GITHUB_READ_ONLY",
                "ghcr.io/github/github-mcp-server"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}",
                "GITHUB_TOOLSETS": "",
                "GITHUB_READ_ONLY": ""
            },
            "disabled": true,
            "alwaysAllow": []
        },
        "git": {
            "command": "python",
            "args": [
                "-m",
                "mcp_server_git",
                "--repository",
                "https://github.com/minhtb105"
            ],
            "disabled": true,
            "alwaysAllow": []
        },
        "memory": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-memory"
            ]
        }
    }
}